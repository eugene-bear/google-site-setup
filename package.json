{
  "name": "@bearmarketing/google-site-setup",
  "version": "1.2.0",
  "description": "CLI to provision GA4, GTM, and Search Console for new websites",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "google-site-setup": "./dist/index.js"
  },
  "files": [
